@DeviceManager_HostAddress = http://localhost:8080
### Create device
POST {{DeviceManager_HostAddress}}/api/v1/devices
Content-Type: application/json

{
  "name": "Galaxy A54",
  "manufacturer": "Samsung",
  "type": "phone",
  "operatingSystem": "Android",
  "osVersion": "16.0",
  "processor": "Exynos 1380",
  "ramAmount": 8,
  "description": "My personal phone. TO DO: Change later to a better description",
  "assignedUserName": null
}

